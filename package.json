{
  "name": "databonk",
  "version": "0.0.3",
  "type": "module",
  "description": "A lightweight, fast data frame library for JavaScript and TypeScript",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test",
    "benchmark": "npm run build && node examples/performance-test.mjs",
    "benchmark:compare": "npm run build && node --loader ts-node/esm examples/benchmark-comparison.ts",
    "serve:examples": "npx http-server examples -p 8080 --cors -o",
    "docker:build": "docker-compose build",
    "docker:dev": "docker-compose up",
    "docker:test": "docker-compose run --rm app npm test",
    "docker:shell": "docker-compose run --rm app sh",
    "docker:benchmark": "docker-compose run --rm app npm run benchmark"
  },
  "keywords": [
    "dataframe",
    "data",
    "analytics",
    "columnar",
    "typescript",
    "javascript",
    "databonk",
    "data-processing",
    "join",
    "aggregation",
    "schema-validation"
  ],
  "author": "Dylan Halpern",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dylanhalpern/databonk.git"
  },
  "homepage": "https://github.com/dylanhalpern/databonk#readme",
  "bugs": {
    "url": "https://github.com/dylanhalpern/databonk/issues"
  },
  "dependencies": {
    "tslib": "^2.8.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.3.1",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/jest": "^29.5.12",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "rollup": "^4.9.6",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "apache-arrow": "^15.0.0"
  },
  "peerDependenciesMeta": {
    "apache-arrow": {
      "optional": true
    }
  }
}
