{
  "name": "databonk",
  "version": "0.0.4",
  "description": "High-performance DataFrame library in AssemblyScript with SIMD acceleration",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "asbuild:debug": "asc assembly/index.ts --target debug",
    "asbuild:release": "asc assembly/index.ts --target release",
    "asbuild": "npm run asbuild:debug && npm run asbuild:release",
    "build:ts": "tsc",
    "build": "npm run asbuild:release && npm run build:ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "benchmark": "node dist/tests/benchmark/million-row.bench.js"
  },
  "keywords": [
    "dataframe",
    "assemblyscript",
    "wasm",
    "simd",
    "columnar",
    "analytics"
  ],
  "author": "Dylan Halpern",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nofurtherinformation/databonk.git"
  },
  "homepage": "https://github.com/nofurtherinformation/databonk#readme",
  "bugs": {
    "url": "https://github.com/nofurtherinformation/databonk/issues"
  },
  "devDependencies": {
    "assemblyscript": "^0.27.29",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "build"
  ]
}
