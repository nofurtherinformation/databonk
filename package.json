{
  "name": "databonk",
  "version": "0.2.0",
  "description": "Columnar WASM dataframe library for JavaScript — pandas-familiar ergonomics, WebAssembly-accelerated kernels, dual ESM/CJS, TypeScript types.",
  "keywords": [
    "dataframe",
    "columnar",
    "wasm",
    "webassembly",
    "data",
    "analytics",
    "simd",
    "arrow",
    "csv",
    "typescript"
  ],
  "license": "MIT",
  "author": "Dylan Halpern <halperndc@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nofurtherinformation/databonk.git"
  },
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./workers": {
      "import": {
        "types": "./dist/workers.d.ts",
        "default": "./dist/workers.js"
      },
      "require": {
        "types": "./dist/workers.d.cts",
        "default": "./dist/workers.cjs"
      }
    },
    "./parquet": {
      "import": {
        "types": "./dist/parquet.d.ts",
        "default": "./dist/parquet.js"
      },
      "require": {
        "types": "./dist/parquet.d.cts",
        "default": "./dist/parquet.cjs"
      }
    }
  },
  "typesVersions": {
    "*": {
      "workers": [
        "./dist/workers.d.ts"
      ],
      "parquet": [
        "./dist/parquet.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:wasm": "bash wasm/rust/build.sh",
    "build:js": "tsup",
    "build": "npm run build:wasm && npm run build:js && node scripts/copy-wasm.mjs",
    "test": "vitest run",
    "test:scalar": "WASM_BUILD=scalar vitest run",
    "test:simd": "WASM_BUILD=simd vitest run",
    "check:readme": "node scripts/check-readme.mjs",
    "gate": "npm run build && npm run test:scalar && npm run test:simd && node scripts/check-size.mjs",
    "gate:bench": "node scripts/check-regression.mjs",
    "fuzz": "node tests/fuzz/fuzz.mjs",
    "bench": "node bench/run.mjs",
    "docs": "typedoc --options typedoc.json",
    "check:publint": "publint",
    "check:attw": "attw databonk-0.2.0.tgz",
    "prepack": "npm run build"
  },
  "dependencies": {
    "hyparquet": "1.26.2",
    "hyparquet-writer": "0.16.1"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "apache-arrow": "^21.1.0",
    "arquero": "^8.0.3",
    "danfojs": "^1.2.0",
    "fast-check": "^3.22.0",
    "parquet-wasm": "0.7.2",
    "publint": "^0.3.0",
    "tinybench": "^2.9.0",
    "tsup": "^8.3.0",
    "typedoc": "^0.28.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
