{
  "family": "temporal",
  "description": "v2 temporal semantic cases: date32 and timestamp logical dtypes dispatching to i32/i64 physical kernels (wasm-abi.md §11). These cases target the REGISTRY+FRAME LAYER (not new wasm kernels): compare/sort/min/max via physical kernel reuse, restricted arithmetic (dtypes.md §9), reinterpret+scale casts (dtypes.md §7.2 incl. negative floor-div), JS-side dt accessors (civil-from-days, weekday ISO 8601, tz-aware Intl), and null propagation. Each case has a 'layer' field: 'kernel_reuse' = runs physical kernel (i32 or i64) with temporal relabeling; 'frame' = JS frame/expr layer; 'frame_error' = must raise a dtype error; 'frame_accessor' = dt accessor path. Physical encoding: date32 = i32 days since 1970-01-01 UTC (proleptic Gregorian); timestamp = i64 ms since 1970-01-01 UTC. BigInt ms values for timestamp are decimal strings per i64 encoding convention.",
  "icu_caveat": "tz-aware accessor expected values computed with Node v22.23.1 (ICU 78.2). America/Chicago DST 2026-03-08 matches the Energy Policy Act of 2005 (US DST rule). Test runner must verify ICU version and skip/warn if mismatched.",
  "cases": [

    { "group": "date32_compare_sort",
      "export": "min_i32_null",
      "name": "date32__min_basic",
      "layer": "kernel_reuse", "dtype_logical": "date32", "dtype_physical": "i32",
      "note": "min of date32 values: physical min_i32_null. Data: [1969-12-31=-1, 1970-01-01=0, 2000-02-29=11016, 2038-01-19=24855]. Min physical = -1 (1969-12-31).",
      "inputs": { "data": [-1, 0, 11016, 24855] },
      "expected": { "result": -1 } },

    { "group": "date32_compare_sort",
      "export": "max_i32_null",
      "name": "date32__max_basic",
      "layer": "kernel_reuse", "dtype_logical": "date32", "dtype_physical": "i32",
      "inputs": { "data": [-1, 0, 11016, 24855] },
      "expected": { "result": 24855 } },

    { "group": "date32_compare_sort",
      "export": "min_i32_null",
      "name": "date32__min_skipna",
      "layer": "kernel_reuse", "dtype_logical": "date32", "dtype_physical": "i32",
      "note": "Null date is skipped; min over non-null values",
      "inputs": { "data": [11016, 0, -1, 0], "vp": [1, 0, 1, 0] },
      "expected": { "result": -1 } },

    { "group": "date32_compare_sort",
      "export": "max_i32_null",
      "name": "date32__max_all_null",
      "layer": "kernel_reuse", "dtype_logical": "date32", "dtype_physical": "i32",
      "note": "All-null: kernel returns 0 (sentinel); API maps to null via count_null",
      "inputs": { "data": [0], "vp": [0] },
      "expected": { "result": 0 } },

    { "group": "date32_compare_sort",
      "export": "argsort_i32",
      "name": "date32__sort_ascending",
      "layer": "kernel_reuse", "dtype_logical": "date32", "dtype_physical": "i32",
      "note": "Ascending sort of date32 values: chronological order. Nulls last. Physical = argsort_i32.",
      "inputs": { "data": [11016, -1, 0, 24855], "inout_perm": [0, 1, 2, 3], "desc": 0 },
      "expected": { "out_perm": [1, 2, 0, 3] } },

    { "group": "date32_compare_sort",
      "export": "argsort_i32",
      "name": "date32__sort_with_null_last",
      "layer": "kernel_reuse", "dtype_logical": "date32", "dtype_physical": "i32",
      "note": "Null date at index 1 sorts last regardless of direction",
      "inputs": { "data": [10, 0, -5], "vp": [1, 0, 1], "inout_perm": [0, 1, 2], "desc": 0 },
      "expected": { "out_perm": [2, 0, 1] } },

    { "group": "date32_compare_sort",
      "export": "eq_i32_mask",
      "name": "date32__compare_equal",
      "layer": "kernel_reuse", "dtype_logical": "date32", "dtype_physical": "i32",
      "note": "date32 equality comparison reuses eq_i32_mask. Same physical day = same date.",
      "inputs": { "a": [0, 11016, -1, 24855], "b": [0, 11016, 0, -1] },
      "expected": { "out_mask": [1, 1, 0, 0] } },

    { "group": "date32_compare_sort",
      "export": "lt_i32_mask",
      "name": "date32__compare_less_than",
      "layer": "kernel_reuse", "dtype_logical": "date32", "dtype_physical": "i32",
      "note": "1969-12-31 < 1970-01-01 < 2000-02-29",
      "inputs": { "a": [-1, 0, 11016], "b": [0, 11016, -1] },
      "expected": { "out_mask": [1, 1, 0] } },

    { "group": "timestamp_compare_sort",
      "export": "min_i64_null",
      "name": "timestamp__min_basic",
      "layer": "kernel_reuse", "dtype_logical": "timestamp", "dtype_physical": "i64",
      "note": "min of timestamps: smallest epoch ms = earliest date. 1969-12-31T00:00:00Z=-86400000; 1970-01-01T00:00:00Z=0; 2000-02-29T00:00:00Z=951782400000.",
      "inputs": { "data": ["-86400000", "0", "951782400000"] },
      "expected": { "result": "-86400000" } },

    { "group": "timestamp_compare_sort",
      "export": "max_i64_null",
      "name": "timestamp__max_skipna",
      "layer": "kernel_reuse", "dtype_logical": "timestamp", "dtype_physical": "i64",
      "note": "max skips null; maximum of the two valid instants",
      "inputs": { "data": ["951782400000", "0", "-86400000"], "vp": [1, 0, 1] },
      "expected": { "result": "951782400000" } },

    { "group": "timestamp_compare_sort",
      "export": "argsort_i64",
      "name": "timestamp__sort_ascending",
      "layer": "kernel_reuse", "dtype_logical": "timestamp", "dtype_physical": "i64",
      "note": "Ascending sort = chronological order. Nulls last.",
      "inputs": { "data": ["951782400000", "-86400000", "0", "2147483647000"],
                  "inout_perm": [0, 1, 2, 3], "desc": 0 },
      "expected": { "out_perm": [1, 2, 0, 3] } },

    { "group": "timestamp_compare_sort",
      "export": "argsort_i64",
      "name": "timestamp__sort_null_last",
      "layer": "kernel_reuse", "dtype_logical": "timestamp", "dtype_physical": "i64",
      "note": "Null timestamp sorts last in ascending",
      "inputs": { "data": ["1000", "0", "-1000"], "vp": [1, 0, 1],
                  "inout_perm": [0, 1, 2], "desc": 0 },
      "expected": { "out_perm": [2, 0, 1] } },

    { "group": "timestamp_compare_sort",
      "export": "eq_i64_mask",
      "name": "timestamp__compare_equal",
      "layer": "kernel_reuse", "dtype_logical": "timestamp", "dtype_physical": "i64",
      "note": "Equal epoch ms = equal instant regardless of tz metadata (tz is display-only, ADR-010)",
      "inputs": { "a": ["0", "951782400000", "1000"], "b": ["0", "951782400000", "2000"] },
      "expected": { "out_mask": [1, 1, 0] } },

    { "group": "restricted_temporal_arithmetic",
      "export": "sub_i64",
      "name": "timestamp_minus_timestamp_duration",
      "layer": "kernel_reuse",
      "dtype_logical_a": "timestamp", "dtype_logical_b": "timestamp", "result_dtype": "i64",
      "note": "timestamp - timestamp -> i64 (duration ms). Lowers to sub_i64 (wasm-abi.md §11). Result is plain integer, not another temporal (ADR-010). Null propagates.",
      "inputs": { "a": ["5000", "1000"], "b": ["1000", "5000"] },
      "expected": { "out": ["4000", "-4000"] } },

    { "group": "restricted_temporal_arithmetic",
      "export": "sub_i64",
      "name": "timestamp_minus_timestamp_null_propagation",
      "layer": "kernel_reuse",
      "dtype_logical_a": "timestamp", "dtype_logical_b": "timestamp", "result_dtype": "i64",
      "note": "Either operand null -> result null (out_valid = a_valid & b_valid, dtypes.md §11)",
      "inputs": { "a": ["5000", "0", "3000"], "b": ["1000", "2000", "0"],
                  "a_vp": [1, 0, 1], "b_vp": [1, 1, 0] },
      "expected": { "out": ["4000", null, null], "out_vp": [1, 0, 0] } },

    { "group": "restricted_temporal_arithmetic",
      "export": "add_i64_scalar",
      "name": "timestamp_plus_ms_scalar",
      "layer": "kernel_reuse",
      "dtype_logical_a": "timestamp", "result_dtype": "timestamp",
      "note": "timestamp + integer-ms (scalar) -> timestamp. Lowers to add_i64_scalar. Result is relabeled timestamp by the frame layer. 1970-01-01T00:00:01 = 1000; +3600000 ms = +1 hour.",
      "inputs": { "a": ["1000", "0", "-86400000"], "s": "3600000" },
      "expected": { "out": ["3601000", "3600000", "-82800000"] } },

    { "group": "restricted_temporal_arithmetic",
      "export": "sub_i64_scalar",
      "name": "timestamp_minus_ms_scalar",
      "layer": "kernel_reuse",
      "dtype_logical_a": "timestamp", "result_dtype": "timestamp",
      "inputs": { "a": ["5000", "1000"], "s": "500" },
      "expected": { "out": ["4500", "500"] } },

    { "group": "restricted_temporal_arithmetic",
      "export": "add_i64",
      "name": "timestamp_plus_ms_col",
      "layer": "kernel_reuse",
      "dtype_logical_a": "timestamp", "dtype_logical_b_or_physical": "i64", "result_dtype": "timestamp",
      "note": "timestamp + i64_ms_column -> timestamp. Lowers to add_i64. Null propagates from either operand.",
      "inputs": { "a": ["1000", "2000", "3000"], "b": ["500", "1000", "0"],
                  "a_vp": [1, 1, 1], "b_vp": [1, 0, 1] },
      "expected": { "out": ["1500", null, "3000"], "out_vp": [1, 0, 1] } },

    { "group": "restricted_temporal_arithmetic",
      "export": "sub_i32",
      "name": "date32_minus_date32_duration_days",
      "layer": "kernel_reuse",
      "dtype_logical_a": "date32", "dtype_logical_b": "date32", "result_dtype": "i32",
      "note": "date32 - date32 -> i32 (duration days). Lowers to sub_i32. 2000-02-29(11016) - 1970-01-01(0) = 11016 days.",
      "inputs": { "a": [11016, 10, 0], "b": [0, 3, -1] },
      "expected": { "out": [11016, 7, 1] } },

    { "group": "restricted_temporal_arithmetic",
      "export": "sub_i32",
      "name": "date32_minus_date32_null_propagation",
      "layer": "kernel_reuse",
      "dtype_logical_a": "date32", "dtype_logical_b": "date32", "result_dtype": "i32",
      "inputs": { "a": [10, 0], "b": [3, 5], "a_vp": [1, 0], "b_vp": [1, 1] },
      "expected": { "out": [7, null], "out_vp": [1, 0] } },

    { "group": "restricted_temporal_arithmetic",
      "export": "add_i32_scalar",
      "name": "date32_plus_days_scalar",
      "layer": "kernel_reuse",
      "dtype_logical_a": "date32", "result_dtype": "date32",
      "note": "date32 + integer-days -> date32. Lowers to add_i32_scalar. 1970-01-01(0)+7=day 7; 1969-12-31(-1)+7=day 6; 2000-02-29(11016)+7=day 11023.",
      "inputs": { "a": [0, -1, 11016], "s": 7 },
      "expected": { "out": [7, 6, 11023] } },

    { "group": "restricted_temporal_arithmetic",
      "export": "sub_i32_scalar",
      "name": "date32_minus_days_scalar",
      "layer": "kernel_reuse",
      "dtype_logical_a": "date32", "result_dtype": "date32",
      "note": "date32 - integer-days -> date32. 1970-01-08(7)-1=6; epoch(0)-1=-1=1969-12-31.",
      "inputs": { "a": [7, 0, 11016], "s": 1 },
      "expected": { "out": [6, -1, 11015] } },

    { "group": "temporal_arithmetic_errors",
      "name": "timestamp_plus_timestamp_error",
      "layer": "frame_error",
      "op": "add", "dtype_a": "timestamp", "dtype_b": "timestamp",
      "note": "timestamp + timestamp is not in the restricted algebra (dtypes.md §9) and MUST raise a dtype error. The test runner verifies that this combination throws.",
      "error_pattern": "timestamp" },

    { "group": "temporal_arithmetic_errors",
      "name": "date32_plus_date32_error",
      "layer": "frame_error",
      "op": "add", "dtype_a": "date32", "dtype_b": "date32",
      "note": "date32 + date32 is not in the restricted algebra and MUST raise a dtype error.",
      "error_pattern": "date32" },

    { "group": "temporal_arithmetic_errors",
      "name": "timestamp_plus_date32_error",
      "layer": "frame_error",
      "op": "add", "dtype_a": "timestamp", "dtype_b": "date32",
      "error_pattern": "timestamp" },

    { "group": "temporal_arithmetic_errors",
      "name": "date32_minus_timestamp_error",
      "layer": "frame_error",
      "op": "sub", "dtype_a": "date32", "dtype_b": "timestamp",
      "error_pattern": "date32" },

    { "group": "temporal_arithmetic_errors",
      "name": "timestamp_mul_error",
      "layer": "frame_error",
      "op": "mul", "dtype_a": "timestamp", "dtype_b": "i64",
      "error_pattern": "timestamp" },

    { "group": "temporal_arithmetic_errors",
      "name": "timestamp_div_error",
      "layer": "frame_error",
      "op": "div", "dtype_a": "timestamp", "dtype_b": "i64",
      "error_pattern": "timestamp" },

    { "group": "temporal_arithmetic_errors",
      "name": "timestamp_plus_f64_error",
      "layer": "frame_error",
      "op": "add", "dtype_a": "timestamp", "dtype_b": "f64",
      "error_pattern": "timestamp" },

    { "group": "temporal_arithmetic_errors",
      "name": "date32_plus_f64_error",
      "layer": "frame_error",
      "op": "add", "dtype_a": "date32", "dtype_b": "f64",
      "error_pattern": "date32" },

    { "group": "temporal_casts",
      "name": "date32_to_i32_reinterpret",
      "layer": "frame", "cast": "date32_to_i32",
      "note": "Free reinterpret: date32->i32 exposes the day count as a plain integer. No value change. No kernel emitted (wasm-abi.md §11).",
      "inputs": { "data_date32": [-1, 0, 11016, 24855] },
      "expected": { "out_i32": [-1, 0, 11016, 24855] } },

    { "group": "temporal_casts",
      "name": "i32_to_date32_reinterpret",
      "layer": "frame", "cast": "i32_to_date32",
      "note": "Free reinterpret: i32 bits become day count. i32(-1) = date32(-1) = 1969-12-31.",
      "inputs": { "data_i32": [-1, 0, 1, 11016] },
      "expected": { "out_date32_days": [-1, 0, 1, 11016] } },

    { "group": "temporal_casts",
      "name": "timestamp_to_i64_reinterpret",
      "layer": "frame", "cast": "timestamp_to_i64",
      "note": "Free reinterpret: timestamp->i64 exposes epoch ms; tz metadata is DROPPED (ADR-010). No kernel.",
      "inputs": { "data_ts_ms": ["-86400000", "0", "951782400000"] },
      "expected": { "out_i64": ["-86400000", "0", "951782400000"] } },

    { "group": "temporal_casts",
      "name": "i64_to_timestamp_reinterpret",
      "layer": "frame", "cast": "i64_to_timestamp",
      "note": "Free reinterpret: i64 bits become UTC epoch ms. Result has no tz.",
      "inputs": { "data_i64": ["-86400000", "0", "951782400000"] },
      "expected": { "out_ts_ms": ["-86400000", "0", "951782400000"] } },

    { "group": "temporal_casts",
      "name": "date32_to_timestamp_scale_cast",
      "layer": "frame", "cast": "date32_to_timestamp",
      "note": "Scale cast: days * 86_400_000 = midnight UTC. Lowered to cast_i32_i64 + mul_i64_scalar(86_400_000). Exact: |days|<2^31 => |ms|<2^58 < 2^63. Null propagates.",
      "inputs": { "data_date32": [-1, 0, 1, 11016], "vp": [1, 1, 1, 1] },
      "expected": {
        "out_ts_ms": ["-86400000", "0", "86400000", "951782400000"],
        "out_vp": [1, 1, 1, 1]
      } },

    { "group": "temporal_casts",
      "name": "date32_to_timestamp_null_propagation",
      "layer": "frame", "cast": "date32_to_timestamp",
      "inputs": { "data_date32": [0, 0, 5], "vp": [1, 0, 1] },
      "expected": {
        "out_ts_ms": ["0", null, "432000000"],
        "out_vp": [1, 0, 1]
      } },

    { "group": "temporal_casts",
      "name": "timestamp_to_date32_floor_div_positive",
      "layer": "frame", "cast": "timestamp_to_date32",
      "note": "Floor division for positive ms equals truncation. Verified: 86400500 ms = 1 day 500 ms -> floor(1.0000057...) = 1.",
      "inputs": { "data_ts_ms": ["0", "86400000", "86400500", "951782400000"], "vp": [1, 1, 1, 1] },
      "expected": { "out_date32": [0, 1, 1, 11016], "out_vp": [1, 1, 1, 1] } },

    { "group": "temporal_casts",
      "name": "timestamp_to_date32_floor_div_negative",
      "layer": "frame", "cast": "timestamp_to_date32",
      "note": "CRITICAL: floor differs from truncation for negative non-exact ms (dtypes.md §7.2 worked example). JS reference: let d = ts/86_400_000n; if (ts%86_400_000n!==0n && ts<0n) d-=1n. Row-by-row working: ts=-1 -> trunc=0 (WRONG), floor=-1=1969-12-31; ts=-86400001 -> trunc=-1 (WRONG), floor=-2=1969-12-30; ts=-86400000 -> exact multiple, trunc=floor=-1=1969-12-31; ts=-172800001 -> trunc=-2 (WRONG), floor=-3=1969-12-29; ts=-172800000 -> exact, trunc=floor=-2=1969-12-30.",
      "inputs": {
        "data_ts_ms": ["-1", "-86400001", "-86400000", "-172800001", "-172800000"],
        "vp": [1, 1, 1, 1, 1]
      },
      "expected": {
        "out_date32": [-1, -2, -1, -3, -2],
        "out_vp": [1, 1, 1, 1, 1]
      } },

    { "group": "temporal_casts",
      "name": "timestamp_to_date32_null_propagation",
      "layer": "frame", "cast": "timestamp_to_date32",
      "inputs": { "data_ts_ms": ["-1", "0", "-86400000"], "vp": [0, 1, 0] },
      "expected": { "out_date32": [null, 0, null], "out_vp": [0, 1, 0] } },

    { "group": "dt_accessors_date32",
      "name": "date32_dt_epoch",
      "layer": "frame_accessor", "dtype": "date32",
      "note": "1970-01-01 (day 0). Thursday=weekday 4 (ISO Mon=1..Sun=7). Day 1 of year. Q1. Derivation: w=((0+3)%7+7)%7=3, weekday=4.",
      "input": { "date32": 0 },
      "expected": { "year": 1970, "month": 1, "day": 1, "hour": 0, "minute": 0, "second": 0, "millisecond": 0, "weekday": 4, "dayOfYear": 1, "quarter": 1 } },

    { "group": "dt_accessors_date32",
      "name": "date32_dt_y2k_leap_day",
      "layer": "frame_accessor", "dtype": "date32",
      "note": "2000-02-29 (day 11016). Leap day. Tuesday=weekday 2 (ISO). Day 60 of year (31+29). Q1.",
      "input": { "date32": 11016 },
      "expected": { "year": 2000, "month": 2, "day": 29, "hour": 0, "minute": 0, "second": 0, "millisecond": 0, "weekday": 2, "dayOfYear": 60, "quarter": 1 } },

    { "group": "dt_accessors_date32",
      "name": "date32_dt_pre_epoch",
      "layer": "frame_accessor", "dtype": "date32",
      "note": "1969-12-31 (day -1). Wednesday=weekday 3 (ISO). Day 365 of 1969 (non-leap). Q4. Derivation: w=((-1+3)%7+7)%7=2, weekday=3.",
      "input": { "date32": -1 },
      "expected": { "year": 1969, "month": 12, "day": 31, "hour": 0, "minute": 0, "second": 0, "millisecond": 0, "weekday": 3, "dayOfYear": 365, "quarter": 4 } },

    { "group": "dt_accessors_date32",
      "name": "date32_dt_y2k38",
      "layer": "frame_accessor", "dtype": "date32",
      "note": "2038-01-19 (day 24855). Tuesday=weekday 2 (ISO). Day 19 of year. Q1.",
      "input": { "date32": 24855 },
      "expected": { "year": 2038, "month": 1, "day": 19, "hour": 0, "minute": 0, "second": 0, "millisecond": 0, "weekday": 2, "dayOfYear": 19, "quarter": 1 } },

    { "group": "dt_accessors_date32",
      "name": "date32_dt_weekday_coverage_sunday_pre_epoch",
      "layer": "frame_accessor", "dtype": "date32",
      "note": "1969-12-28 (day -4). Sunday=weekday 7 (ISO). Derivation: w=((-4+3)%7+7)%7=((-1)%7+7)%7=(-1+7)%7=6, weekday=7. Confirms negative-safe modulo.",
      "input": { "date32": -4 },
      "expected": { "year": 1969, "month": 12, "day": 28, "weekday": 7 } },

    { "group": "dt_accessors_date32",
      "name": "date32_dt_weekday_coverage_monday",
      "layer": "frame_accessor", "dtype": "date32",
      "note": "1970-01-05 (day 4). Monday=weekday 1 (ISO). Derivation: w=((4+3)%7+7)%7=0, weekday=1.",
      "input": { "date32": 4 },
      "expected": { "year": 1970, "month": 1, "day": 5, "weekday": 1 } },

    { "group": "dt_accessors_date32",
      "name": "date32_dt_weekday_coverage_full_week",
      "layer": "frame_accessor", "dtype": "date32",
      "note": "ISO weekday for days -4..+3 covering a full week (Sun 1969-12-28 to Sun 1970-01-04). Derivation per ADR-010.",
      "inputs": [
        { "date32": -4, "expected_weekday": 7, "date": "1969-12-28 Sun" },
        { "date32": -3, "expected_weekday": 1, "date": "1969-12-29 Mon" },
        { "date32": -2, "expected_weekday": 2, "date": "1969-12-30 Tue" },
        { "date32": -1, "expected_weekday": 3, "date": "1969-12-31 Wed" },
        { "date32":  0, "expected_weekday": 4, "date": "1970-01-01 Thu" },
        { "date32":  1, "expected_weekday": 5, "date": "1970-01-02 Fri" },
        { "date32":  2, "expected_weekday": 6, "date": "1970-01-03 Sat" },
        { "date32":  3, "expected_weekday": 7, "date": "1970-01-04 Sun" }
      ] },

    { "group": "dt_accessors_date32",
      "name": "date32_dt_null",
      "layer": "frame_accessor", "dtype": "date32",
      "note": "Null date32 row: all accessor fields are null (validity copied from input, dtypes.md §11).",
      "input": { "date32": null },
      "expected": { "year": null, "month": null, "day": null, "weekday": null, "dayOfYear": null, "quarter": null } },

    { "group": "dt_accessors_timestamp_utc",
      "name": "timestamp_dt_utc_epoch",
      "layer": "frame_accessor", "dtype": "timestamp", "tz": null,
      "note": "1970-01-01T00:00:00.000Z = 0 ms. dayNum=0, msOfDay=0.",
      "input": { "ts_ms": "0" },
      "expected": { "year": 1970, "month": 1, "day": 1, "hour": 0, "minute": 0, "second": 0, "millisecond": 0, "weekday": 4, "dayOfYear": 1, "quarter": 1 } },

    { "group": "dt_accessors_timestamp_utc",
      "name": "timestamp_dt_utc_hms",
      "layer": "frame_accessor", "dtype": "timestamp", "tz": null,
      "note": "1970-01-01T01:02:03.000Z = 3723000 ms. dayNum=0, msOfDay=3723000. hour=1, min=2, sec=3.",
      "input": { "ts_ms": "3723000" },
