      "inputs": { "in": [0, 1, -1, 2147483647, -2147483648], "in_vp": [1, 1, 1, 1, 1] },
      "expected": { "out": [0.0, 1.0, -1.0, 2147483647.0, -2147483648.0], "out_vp": [1, 1, 1, 1, 1] } },
    { "export": "cast_i32_f64", "name": "cast_i32_f64__null_propagates",
      "inputs": { "in": [5], "in_vp": [0] }, "expected": { "out": [null], "out_vp": [0] } },
    { "export": "cast_i32_f64", "name": "cast_i32_f64__no_null_fast_path",
      "inputs": { "in": [42, -42] }, "expected": { "out": [42.0, -42.0], "out_vp": [1, 1] } },

    { "export": "cast_i32_f32", "name": "cast_i32_f32__precision_loss",
      "note": "16777217 = 2^24+1 cannot be represented exactly in f32; rounds to 16777216 (ties-to-even)",
      "inputs": { "in": [1, -1, 16777217], "in_vp": [1, 1, 1] },
      "expected": { "out": [1.0, -1.0, 16777216.0], "out_vp": [1, 1, 1] } },
    { "export": "cast_i32_f32", "name": "cast_i32_f32__null_propagates",
      "inputs": { "in": [1, 2], "in_vp": [1, 0] }, "expected": { "out": [1.0, null], "out_vp": [1, 0] } },

    { "export": "cast_i32_u32", "name": "cast_i32_u32__negative_to_null",
      "note": "Negative i32 → null; non-negative i32 → same bit pattern as u32",
      "inputs": { "in": [0, 2147483647, -1, -2147483648], "in_vp": [1, 1, 1, 1] },
      "expected": { "out": [0, 2147483647, null, null], "out_vp": [1, 1, 0, 0] } },
    { "export": "cast_i32_u32", "name": "cast_i32_u32__null_propagates",
      "inputs": { "in": [5], "in_vp": [0] }, "expected": { "out": [null], "out_vp": [0] } },

    { "export": "cast_i32_bool", "name": "cast_i32_bool__nonzero_true_zero_false",
      "inputs": { "in": [0, 1, -1, 2, -100], "in_vp": [1, 1, 1, 1, 1] },
      "expected": { "out": [0, 1, 1, 1, 1], "out_vp": [1, 1, 1, 1, 1] } },
    { "export": "cast_i32_bool", "name": "cast_i32_bool__null_propagates",
      "inputs": { "in": [5], "in_vp": [0] }, "expected": { "out": [null], "out_vp": [0] } },

    { "export": "cast_u32_f64", "name": "cast_u32_f64__exact_conversion",
      "inputs": { "in": [0, 1, 2147483648, 4294967295], "in_vp": [1, 1, 1, 1] },
      "expected": { "out": [0.0, 1.0, 2147483648.0, 4294967295.0], "out_vp": [1, 1, 1, 1] } },
    { "export": "cast_u32_f64", "name": "cast_u32_f64__null_propagates",
      "inputs": { "in": [1], "in_vp": [0] }, "expected": { "out": [null], "out_vp": [0] } },

    { "export": "cast_u32_f32", "name": "cast_u32_f32__precision_loss",
      "note": "Same threshold as i32→f32: values > 2^24 may lose precision",
      "inputs": { "in": [1, 16777217, 4294967295], "in_vp": [1, 1, 1] },
      "expected": { "out": [1.0, 16777216.0, 4294967296.0], "out_vp": [1, 1, 1] },
      "note2": "4294967295 rounds to 4294967296.0 in f32 (nearest f32 >= 2^32)" },
    { "export": "cast_u32_f32", "name": "cast_u32_f32__null_propagates",
      "inputs": { "in": [1], "in_vp": [0] }, "expected": { "out": [null], "out_vp": [0] } },

    { "export": "cast_u32_i32", "name": "cast_u32_i32__overflow_to_null",
      "note": "u32 values > 2^31-1 cannot be represented as i32 → null",
      "inputs": { "in": [0, 2147483647, 2147483648, 4294967295], "in_vp": [1, 1, 1, 1] },
      "expected": { "out": [0, 2147483647, null, null], "out_vp": [1, 1, 0, 0] } },
    { "export": "cast_u32_i32", "name": "cast_u32_i32__null_propagates",
      "inputs": { "in": [5], "in_vp": [0] }, "expected": { "out": [null], "out_vp": [0] } },

    { "export": "cast_u32_bool", "name": "cast_u32_bool__nonzero_true",
      "inputs": { "in": [0, 1, 4294967295], "in_vp": [1, 1, 1] },
      "expected": { "out": [0, 1, 1], "out_vp": [1, 1, 1] } },
    { "export": "cast_u32_bool", "name": "cast_u32_bool__null_propagates",
      "inputs": { "in": [0], "in_vp": [0] }, "expected": { "out": [null], "out_vp": [0] } },

    { "export": "cast_bool_f64", "name": "cast_bool_f64__exact",
      "note": "bool→f64 is exact: true→1.0, false→0.0",
      "inputs": { "in": [1, 0, 1, 0], "in_vp": [1, 1, 1, 1] },
      "expected": { "out": [1.0, 0.0, 1.0, 0.0], "out_vp": [1, 1, 1, 1] } },
    { "export": "cast_bool_f64", "name": "cast_bool_f64__null_propagates",
      "inputs": { "in": [1, 0], "in_vp": [0, 1] },
      "expected": { "out": [null, 0.0], "out_vp": [0, 1] } },

    { "export": "cast_bool_f32", "name": "cast_bool_f32__exact",
      "inputs": { "in": [1, 0], "in_vp": [1, 1] },
      "expected": { "out": [1.0, 0.0], "out_vp": [1, 1] } },
    { "export": "cast_bool_f32", "name": "cast_bool_f32__null_propagates",
      "inputs": { "in": [1], "in_vp": [0] }, "expected": { "out": [null], "out_vp": [0] } },

    { "export": "cast_bool_i32", "name": "cast_bool_i32__exact",
      "inputs": { "in": [1, 0], "in_vp": [1, 1] },
      "expected": { "out": [1, 0], "out_vp": [1, 1] } },
    { "export": "cast_bool_i32", "name": "cast_bool_i32__null_propagates",
      "inputs": { "in": [0], "in_vp": [0] }, "expected": { "out": [null], "out_vp": [0] } },

    { "export": "cast_bool_u32", "name": "cast_bool_u32__exact",
      "inputs": { "in": [1, 0], "in_vp": [1, 1] },
      "expected": { "out": [1, 0], "out_vp": [1, 1] } },
    { "export": "cast_bool_u32", "name": "cast_bool_u32__null_propagates",
      "inputs": { "in": [1], "in_vp": [0] }, "expected": { "out": [null], "out_vp": [0] } },

    { "export": "fill_null_f64", "name": "fill_null_f64__empty",
      "inputs": { "in": [], "fill": 0.0 }, "expected": { "out": [] } },
    { "export": "fill_null_f64", "name": "fill_null_f64__mixed_nulls",
      "note": "Null positions get fill value; output has no nulls (all-valid)",
      "inputs": { "in": [1.0, 0.0, 3.0], "in_vp": [1, 0, 1], "fill": 99.0 },
      "expected": { "out": [1.0, 99.0, 3.0] } },
    { "export": "fill_null_f64", "name": "fill_null_f64__all_null",
      "inputs": { "in": [0.0, 0.0], "in_vp": [0, 0], "fill": 7.5 },
      "expected": { "out": [7.5, 7.5] } },
    { "export": "fill_null_f64", "name": "fill_null_f64__no_null_fast_path",
      "note": "Omitting in_vp passes validity_ptr=0; output unchanged",
      "inputs": { "in": [1.0, 2.0, 3.0], "fill": 0.0 },
      "expected": { "out": [1.0, 2.0, 3.0] } },
    { "export": "fill_null_f64", "name": "fill_null_f64__nan_fill_value",
      "note": "NaN is a valid fill value (it is not null)",
      "inputs": { "in": [1.0, 0.0], "in_vp": [1, 0], "fill": "NaN" },
      "expected": { "out": [1.0, "NaN"] } },

    { "export": "fill_null_f32", "name": "fill_null_f32__basic",
      "inputs": { "in": [1.5, 0.0], "in_vp": [1, 0], "fill": 9.0 },
      "expected": { "out": [1.5, 9.0] } },

    { "export": "fill_null_i32", "name": "fill_null_i32__basic",
      "inputs": { "in": [0, 0, 5], "in_vp": [0, 1, 1], "fill": -1 },
      "expected": { "out": [-1, 0, 5] } },
    { "export": "fill_null_i32", "name": "fill_null_i32__len9_bitmap_padding",
      "inputs": {
        "in":    [1, 2, 3, 4, 5, 6, 7, 8,  9],
        "in_vp": [1, 1, 0, 1, 0, 1, 1, 1,  0],
        "fill": 0
      },
      "expected": { "out": [1, 2, 0, 4, 0, 6, 7, 8, 0] } },

    { "export": "fill_null_u32", "name": "fill_null_u32__basic",
      "inputs": { "in": [0, 0, 5], "in_vp": [0, 0, 1], "fill": 4294967295 },
      "expected": { "out": [4294967295, 4294967295, 5] } },

    { "export": "is_null", "name": "is_null__empty",
      "note": "is_null takes only vp and len; output is u8 bool array (1=null, 0=valid)",
      "inputs": { "vp": [] }, "expected": { "out_bool": [] } },
    { "export": "is_null", "name": "is_null__mixed",
      "inputs": { "vp": [1, 0, 1, 0, 1] },
      "expected": { "out_bool": [0, 1, 0, 1, 0] } },
    { "export": "is_null", "name": "is_null__all_valid",
      "inputs": { "vp": [1, 1, 1] }, "expected": { "out_bool": [0, 0, 0] } },
    { "export": "is_null", "name": "is_null__all_null",
      "inputs": { "vp": [0, 0, 0] }, "expected": { "out_bool": [1, 1, 1] } },
    { "export": "is_null", "name": "is_null__explicitly_all_valid",
      "note": "All validity bits set to 1 → is_null output is all 0",
      "inputs": { "vp": [1, 1, 1] }, "expected": { "out_bool": [0, 0, 0] } },
    { "export": "is_null", "name": "is_null__len9_bitmap_padding",
      "inputs": { "vp": [1,0,1,0,1,0,1,0, 1] },
      "expected": { "out_bool": [0,1,0,1,0,1,0,1, 0] } },

    { "export": "expand_mask_bool", "name": "expand_mask_bool__empty",
      "note": "Expand 1-bit mask to u8 bool column",
      "inputs": { "mask": [] }, "expected": { "out_u8": [] } },
    { "export": "expand_mask_bool", "name": "expand_mask_bool__basic",
      "inputs": { "mask": [0, 1, 1, 0, 1] },
      "expected": { "out_u8": [0, 1, 1, 0, 1] } },
    { "export": "expand_mask_bool", "name": "expand_mask_bool__all_set",
      "inputs": { "mask": [1, 1, 1, 1] }, "expected": { "out_u8": [1, 1, 1, 1] } },
    { "export": "expand_mask_bool", "name": "expand_mask_bool__len9_padding_ignored",
      "note": "Padding bits in byte 2 (positions 9–15) must be ignored; only 9 elements output",
      "inputs": { "mask": [1,0,1,0,1,0,1,0, 1] },
      "expected": { "out_u8": [1,0,1,0,1,0,1,0, 1] } }
  ]
}
