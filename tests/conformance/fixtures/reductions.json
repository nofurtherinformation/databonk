    { "export": "count_null", "name": "count_null__mixed",
      "inputs": { "vp": [1, 0, 1, 0, 1] }, "expected": { "result": 3 } },
    { "export": "count_null", "name": "count_null__all_null",
      "inputs": { "vp": [0, 0, 0] }, "expected": { "result": 0 } },
    { "export": "count_null", "name": "count_null__len9_bitmap_padding",
      "note": "9 elements: 5 valid, 4 null",
      "inputs": { "vp": [1,0,1,0,1,0,1,0, 1] }, "expected": { "result": 5 } },

    { "export": "std_f64_null", "name": "std_f64_null__basic",
      "note": "Sample std dev ddof=1. data=[2,4,4,4,5,5,7,9]; mean=5, SS=32, var=32/7, std=sqrt(32/7)≈2.138089935299395",
      "inputs": { "data": [2.0, 4.0, 4.0, 4.0, 5.0, 5.0, 7.0, 9.0] },
      "expected": { "result": 2.138089935299395 } },
