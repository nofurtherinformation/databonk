      "expected": { "result": 2.0 } },
    { "export": "std_f64_null", "name": "std_f64_null__one_non_null",
      "note": "Fewer than 2 non-null values → null at API level; kernel returns NaN (wasm-abi.md §9: std/var < 2 non-null → NaN)",
      "inputs": { "data": [5.0, 0.0], "vp": [1, 0] }, "expected": { "result": "NaN" } },
    { "export": "std_f64_null", "name": "std_f64_null__all_null",
