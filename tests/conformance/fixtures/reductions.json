    { "export": "var_i32_null", "name": "var_i32_null__basic",
      "inputs": { "data": [1, 3, 5] }, "expected": { "result": 4.0 } },

    { "export": "std_u32_null", "name": "std_u32_null__basic",
      "inputs": { "data": [1, 3, 5] }, "expected": { "result": 2.0 } },
    { "export": "var_u32_null", "name": "var_u32_null__basic",
      "inputs": { "data": [1, 3, 5] }, "expected": { "result": 4.0 } },

    { "export": "nunique_f64_null", "name": "nunique_f64_null__empty",
      "note": "nunique of empty → 0",
      "inputs": { "data": [], "vp": [] }, "expected": { "result": 0 } },
    { "export": "nunique_f64_null", "name": "nunique_f64_null__all_distinct",
